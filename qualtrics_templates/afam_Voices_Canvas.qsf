oring","SecondaryAttribute":null,"TertiaryAttribute":null,"Payload":{"ScoringCategories":[],"ScoringCategoryGroups":[],"ScoringSummaryCategory":null,"ScoringSummaryAfterQuestions":0,"ScoringSummaryAfterSurvey":0,"DefaultScoringCategory":null,"AutoScoringCategory":null}},{"SurveyID":"SV_bNoL7N0zZfv5tae","Element":"SO","PrimaryAttribute":"Survey Options","SecondaryAttribute":null,"TertiaryAttribute":null,"Payload":{"BackButton":"false","SaveAndContinue":"true","SurveyProtection":"PublicSurvey","BallotBoxStuffingPrevention":"false","NoIndex":"Yes","SecureResponseFiles":"true","SurveyExpiration":null,"SurveyTermination":"DisplayMessage","Header":"","Footer":"","ProgressBarDisplay":"None","PartialData":"+2 weeks","ValidationMessage":null,"PreviousButton":" \u2190 ","NextButton":" \u2192 ","SurveyTitle":"Interpreting Emotion from Masked and Unmasked Faces","SkinLibrary":"georgiasouthern","SkinType":"MQ","Skin":"skin1","NewScoring":1,"EOSMessage":"MS_9vKxfWD98eSmJbD","ShowExportTags":"false","CollectGeoLocation":"false","SurveyMetaDescription":"The most powerful, simple and trusted way to gather experience data. Start your journey to experience management and try a free account today.","PasswordProtection":"No","AnonymizeResponse":"Yes","Password":"","RefererCheck":"No","RefererURL":"http:\/\/","UseCustomSurveyLinkCompletedMessage":null,"SurveyLinkCompletedMessage":"","SurveyLinkCompletedMessageLibrary":"","ResponseSummary":"No","EOSMessageLibrary":"UR_8oE5QK28HTho1TL","EOSRedirectURL":"https:\/\/","EmailThankYou":"false","ThankYouEmailMessageLibrary":null,"ThankYouEmailMessage":null,"ValidateMessage":"false","ValidationMessageLibrary":null,"InactiveSurvey":"DefaultMessage","PartialDataCloseAfter":"LastActivity","ActiveResponseSet":null,"InactiveMessageLibrary":"","InactiveMessage":"","AvailableLanguages":{"EN":[]}}},{"SurveyID":"SV_bNoL7N0zZfv5tae","Element":"SQ","PrimaryAttribute":"QID1","SecondaryAttribute":"This demonstration of the DANVA2 is being conducted by XXX at XXX University in order to understa...","TertiaryAttribute":null,"Payload":{"QuestionText":"<p><span style=\"font-family: &quot;Lucida Sans Unicode&quot;, &quot;Lucida Grande&quot;, sans-serif;\">This demonstration of the DANVA2 is being conducted by XXX at XXX University in order to understand more about students\u2019 abilities to interpret emotions from adult faces.<\/span><\/p>\n<br>\n<span style=\"font-family:Lucida Sans Unicode,Lucida Grande,sans-serif;\">Purpose of the study: The purpose of this demonstration is to determine how accurate students are at interpreting emotions from faces.<\/span><br>\n<br>\n<span style=\"font-family:Lucida Sans Unicode,Lucida Grande,sans-serif;\">Procedures: For participation in this demonstration you will identify the emotion shown in a variety of photographs of people's faces. You will not provide some background information about yourself. You will be asked to generate a code that only you will know so you can find your answers in the data without anyone else in class knowing which results are yours. If you just want to try it out without providing a code, that is fine - but I will not be able to show your personal results to you.<\/span><br>\n<br>\n<span style=\"font-family:Lucida Sans Unicode,Lucida Grande,sans-serif;\">Discomforts and Risks:&nbsp;There are no risks to participants beyond those encountered in everyday life. If you feel uncomfortable, you may skip any question or skip to the end of the survey at any time without penalty or loss of benefits. Your identity will remain anonymous. Your computer's IP address&nbsp;will not be collected. The responses are being collected with software that is designed to secure the data and provide you with confidentiality. Nevertheless, despite these safeguards, there is always a remote possibility of hacking or other security breaches that could compromise the confidentiality of the information you provide. For that reason, we encourage you to be sure that you complete this demonstration from a computer with updated virus protection.&nbsp;<\/span><br>\n<br>\n<span style=\"font-family:Lucida Sans Unicode,Lucida Grande,sans-serif;\">Benefits: As a result of participating in this classroom demonstration, you may become more aware of your ability (or challenges) in interpreting facial expressions.<\/span><br>\n<br>\n<span style=\"font-family:Lucida Sans Unicode,Lucida Grande,sans-serif;\">Duration: This demonstration will take approximately 10 minutes to complete.<\/span><br>\n<br>\n<span style=\"font-family:Lucida Sans Unicode,Lucida Grande,sans-serif;\">Statement of Confidentiality:&nbsp;When you reach the end of the demonstration, I will download the data, score it, and provide it to the class so you can find your individual results. I will have access to your anonymous survey responses, which will be stored on a password-protected computer, network drive, or Google drive. Your responses will be maintained in this secure location for a minimum of the end of the semester following completion of the demonstration.<\/span><br>\n<br>\n<span style=\"font-family:Lucida Sans Unicode,Lucida Grande,sans-serif;\">Future use of the data: Given this is a classroom demonstration and not a research study, your data will not be presented nor published. They are for classroom use and discussion, as well as testing out measures that may be used in future research.&nbsp;<\/span><div><span style=\"font-family:Lucida Sans Unicode,Lucida Grande,sans-serif;\"><br><\/span><\/div><div><span style=\"font-family:Lucida Sans Unicode,Lucida Grande,sans-serif;\">Right to ask questions: If you have questions about this demonstration, please discuss them with me. My contact information is located at the end of this introductory segment.&nbsp;&nbsp;<\/span><\/div><div><font face=\"Lucida Sans Unicode, Lucida Grande, sans-serif\"><br><\/font>\n<span style=\"font-family:Lucida Sans Unicode,Lucida Grande,sans-serif;\">Compensation:&nbsp; There is no compensation for participating in this class demonstration.<\/span><\/div><div><font face=\"Lucida Sans Unicode, Lucida Grande, sans-serif\"><br><\/font>\n<span style=\"font-family:Lucida Sans Unicode,Lucida Grande,sans-serif;\">Voluntary Participation: You may end your participation in this class demonstration at any time by closing out of the survey window on your computer. You do not have to answer any questions that you do not want to answer.<\/span><br>\n<br>\n<span style=\"font-family:Lucida Sans Unicode,Lucida Grande,sans-serif;\">Penalty:&nbsp; You may decide at any time that you do not want to participate further and may withdraw without penalty or retribution.&nbsp;<\/span><br><div><p><br><\/p>\n\n<p><span style=\"font-family:Lucida Sans Unicode,Lucida Grande,sans-serif;\"><u>Title of Demonstration<\/u>: Interpreting Emotion from Adult Faces<\/span><\/p>\n\n<p><span style=\"font-family:Lucida Sans Unicode,Lucida Grande,sans-serif;\"><u>Contact Information<\/u>: Dr. XXX, Department of Psychology, ADDRESS. name@yourschool.edu<\/span><o:p><\/o:p><\/p><p><span style=\"font-family:Lucida Sans Unicode,Lucida Grande,sans-serif;\"><br><\/span><\/p>\n<span style=\"font-family:Lucida Sans Unicode,Lucida Grande,sans-serif;\"> <\/span><o:p><\/o:p>\n\n<p><span style=\"font-family:Lucida Sans Unicode,Lucida Grande,sans-serif;\">Completion of the demonstration implies that you agree to participate and that your anonymous data may be shared with your professor and your classmates. If you agree to continue with this demonstration, please check all of the following statements.<\/span><o:p><\/o:p><\/p><\/div><\/div>","DefaultChoices":false,"DataExportTag":"Q1","QuestionType":"DB","Selector":"TB","Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"This demonstration of the DANVA2 is being conducted by XXX at XXX University in order to understa...","ChoiceOrder":[],"Validation":{"Settings":{"Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":11,"NextAnswerId":1,"QuestionID":"QID1","DataVisibility":{"Private":false,"Hidden":false}}},{"SurveyID":"SV_bNoL7N0zZfv5tae","Element":"SQ","PrimaryAttribute":"QID18","SecondaryAttribute":"Please adjust your volume until you can hear the voice clearly. Click the next arrow when ready t...","TertiaryAttribute":null,"Payload":{"QuestionText":"Please adjust your volume until you can hear the voice clearly.&nbsp; Click the next arrow when ready to continue.","DefaultChoices":false,"DataExportTag":"Q18","QuestionID":"QID18","QuestionType":"DB","Selector":"TB","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"Please adjust your volume until you can hear the voice clearly. Click the next arrow when ready t...","ChoiceOrder":[],"Randomization":{"Advanced":null,"TotalRandSubset":"1","Type":"SubSet"},"Validation":{"Settings":{"Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":3,"NextAnswerId":1,"QuestionJS":"Qualtrics.SurveyEngine.addOnReady(function () {\n\n    var qthis = this;\n\n    \/\/ Hide Next button for 5 seconds\n    qthis.hideNextButton();\n    setTimeout(function () {\n        qthis.showNextButton();\n    }, 5000);\n\n    \/\/ Create audio element\n    var audio = document.createElement(\"audio\");\n    audio.src = \"https:\/\/raw.githubusercontent.com\/MichaelWoodc\/DANVA2\/refs\/heads\/main\/src\/stimFiles\/volume_prompt.wav\";\n    audio.preload = \"auto\";\n    audio.loop = true;   \/\/ continuous playback\n\n    \/\/ Add audio to page\n    this.getQuestionContainer().appendChild(audio);\n\n    \/\/ Create Play and Pause buttons\n    var playBtn = document.createElement(\"button\");\n    playBtn.textContent = \"Play\";\n    playBtn.style.fontSize = \"18px\";\n    playBtn.style.marginRight = \"10px\";\n\n    var pauseBtn = document.createElement(\"button\");\n    pauseBtn.textContent = \"Pause\";\n    pauseBtn.style.fontSize = \"18px\";\n\n    \/\/ Add buttons to page\n    var qc = this.getQuestionContainer();\n    qc.appendChild(playBtn);\n    qc.appendChild(pauseBtn);\n\n    \/\/ Start playing automatically when ready\n    audio.addEventListener(\"canplaythrough\", function () {\n        audio.play();\n    });\n\n    \/\/ Button controls\n    playBtn.addEventListener(\"click\", function () {\n        audio.play();\n    });\n\n    pauseBtn.addEventListener(\"click\", function () {\n        audio.pause();\n    });\n\n});"}},{"SurveyID":"SV_bNoL7N0zZfv5tae","Element":"SQ","PrimaryAttribute":"QID185","SecondaryAttribute":"Click to write the question text","TertiaryAttribute":null,"Payload":{"QuestionText":"Click to write the question text","DataExportTag":"Q77","QuestionType":"MC","Selector":"SAVR","SubSelector":"TX","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"Click to write the question text","Choices":{"1":{"Display":"Click to write Choice 1"},"2":{"Display":"Click to write Choice 2"},"3":{"Display":"Click to write Choice 3"}},"ChoiceOrder":["1","2","3"],"Validation":{"Settings":{"ForceResponse":"OFF","Type":"None"}},"Language":[],"NextChoiceId":4,"NextAnswerId":1,"QuestionID":"QID185"}},{"SurveyID":"SV_bNoL7N0zZfv5tae","Element":"SQ","PrimaryAttribute":"QID186","SecondaryAttribute":"Click to write the question text","TertiaryAttribute":null,"Payload":{"QuestionText":"Click to write the question text","DataExportTag":"Q78","QuestionType":"MC","Selector":"SAVR","SubSelector":"TX","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"Click to write the question text","Choices":{"1":{"Display":"Click to write Choice 1"},"2":{"Display":"Click to write Choice 2"},"3":{"Display":"Click to write Choice 3"}},"ChoiceOrder":["1","2","3"],"Validation":{"Settings":{"ForceResponse":"OFF","Type":"None"}},"Language":[],"NextChoiceId":4,"NextAnswerId":1,"QuestionID":"QID186"}},{"SurveyID":"SV_bNoL7N0zZfv5tae","Elem